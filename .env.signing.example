# Keep the real PFX and this populated file outside source control.
# Use a certificate issued to The Griffin by a trusted provider, or configure
# Azure Trusted Signing through a separate Windows-sign hook.
WINDOWS_CERTIFICATE_FILE=C:\secure\griffin-menu-studio-signing.pfx
WINDOWS_CERTIFICATE_PASSWORD=replace-with-the-certificate-password
# Optional. The Electron signing default is also suitable when omitted.
WINDOWS_TIMESTAMP_SERVER=http://timestamp.digicert.com
