{
  "name": "griffin-menu-studio",
  "productName": "Griffin Menu Studio",
  "version": "1.1.1",
  "description": "Desktop menu editor and print/export tool for The Griffin.",
  "main": ".vite/build/main.js",
  "author": "The Griffin",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/RogerPerowne/the-griffin-menu-studio.git"
  },
  "scripts": {
    "start": "electron-forge start",
    "assets:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-wix-assets.ps1",
    "package": "electron-forge package",
    "make": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-windows.ps1",
    "make:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:GRIFFIN_CHANNEL='dev'; & scripts/make-windows.ps1\"",
    "release": "node scripts/publish-release.mjs",
    "make:release": "node scripts/require-windows-signing.cjs && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-windows.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-signatures.ps1",
    "publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-windows.ps1",
    "verify:signatures": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-signatures.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-wix": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@types/node": "^22.10.0",
    "@types/pngjs": "^6.0.5",
    "electron": "^43.1.0",
    "png-to-ico": "^3.0.2",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "update-electron-app": "^3.3.0"
  }
}
